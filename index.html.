  { id:"A2", cat:"brise-glace", nom:"Portrait Croisé", duree:"20–30 min", participants:"6–40", obj:"Favoriser la prise de contact rapide ; développer l'écoute active ; permettre à chacun d'être présenté par un pair.", dom:"Savoir-agir — affectif", bloom:"Niveau 2", style:"Participatif", mat:"Fiche d'entretien guidé (3–5 questions), chronomètre.", der:["Constitution des binômes (2 min).","Entretien croisé (5–7 min).","Présentation de l'autre en plénière.","Réaction de l'intéressé (30 sec).","Synthèse par le formateur."], av:"Réduit l'anxiété de l'auto-présentation. Développe immédiatement l'écoute active.", lim:"Qualité dépendante de la fiche d'entretien et de l'écoute.", ex:"Étudiants infirmiers de promotions différentes : spécialité préférée, geste maîtrisé, difficulté relationnelle principale." },
  { id:"A3", cat:"brise-glace", nom:"2 Vérités et 1 Mensonge", duree:"15–25 min", participants:"6–30", obj:"Créer une dynamique ludique de découverte mutuelle ; favoriser les échanges informels.", dom:"Savoir-agir — affectif", bloom:"Niveau 2", style:"Participatif", mat:"Aucun matériel obligatoire.", der:["Explication de la règle (2 min).","Préparation individuelle (3–4 min).","Tour de table — le groupe vote.","Révélation et anecdote.","Rebond thématique du formateur."], av:"Très rapide. Atmosphère détendue et ludique.", lim:"Peut être inconfortable pour des introvertis. Veiller au registre professionnel.", ex:"En formation continue, un médecin révèle 10 ans en zone rurale, une infirmière parle 4 langues." },
  { id:"A4", cat:"brise-glace", nom:"La Météo du Jour", duree:"10–20 min", participants:"6–35", obj:"Permettre à chaque participant d'exprimer son état d'esprit de manière symbolique ; donner au formateur une lecture rapide du climat.", dom:"Savoir-agir — affectif", bloom:"Niveaux 1–2", style:"Participatif et permissif", mat:"Optionnel : carte météo illustrée, post-its.", der:["Présentation de la métaphore.","Modélisation par le formateur.","Tour de table (30–60 sec/personne).","Cartographie collective.","Transition pédagogique."], av:"Très rapide et non menaçante. Développe l'intelligence émotionnelle.", lim:"Peut rester superficielle si confiance insuffisante.", ex:"En début de séance sur la gestion du stress en soins intensifs, la majorité exprime nuages et brouillard — le formateur adapte." },
  { id:"A5", cat:"brise-glace", nom:"Le Bingo des Compétences", duree:"20–30 min", participants:"12–40", obj:"Favoriser les échanges et la connaissance mutuelle ; cartographier les expériences présentes.", dom:"Savoir — identification", bloom:"Niveaux 1–2", style:"Participatif", mat:"Grilles Bingo personnalisées pré-imprimées (4×4 ou 5×5).", der:["Distribution des grilles.","Circulation libre (10–15 min).","Cri de Bingo et vérification.","Mise en commun collective."], av:"Mouvement physique dynamisant. Cartographie rapide des ressources.", lim:"Requiert une préparation en amont. Peut être bruyant.", ex:"Journée interprofessionnelle : la grille révèle des expertises méconnues entre collègues d'un même établissement." },
  { id:"A6", cat:"brise-glace", nom:"Le Mur des Attentes", duree:"15–25 min", participants:"8–40", obj:"Recueillir et visualiser les attentes, besoins et craintes ; permettre au formateur d'ajuster son programme.", dom:"Savoir — clarification", bloom:"Niveau 2", style:"Participatif", mat:"Post-its 3 couleurs (vert/orange/rouge), tableau blanc.", der:["Explication du code couleur.","Rédaction individuelle (5–7 min).","Affichage et organisation par thèmes.","Lecture et régulation par le formateur.","Contrat pédagogique."], av:"Donne la parole aux apprenants. Ajuste le programme aux besoins réels.", lim:"Frustration possible si attentes non traitées. Requiert de la flexibilité.", ex:"Avant une formation urgences obstétricales, le Mur révèle la crainte dominante de l'hémorragie massive — le formateur priorise la simulation." },
  { id:"A7", cat:"brise-glace", nom:"La Ligne du Temps Professionnelle", duree:"30–50 min", participants:"6–20", obj:"Permettre de retracer son parcours professionnel ; créer une réflexivité sur l'évolution identitaire.", dom:"Savoir-agir — réflexivité", bloom:"Niveaux 2–5", style:"Participatif et permissif", mat:"Grandes feuilles horizontales, marqueurs, post-its, étoiles.", der:["Distribution et explication.","Construction individuelle (10–15 min).","Partage en binômes.","Présentation en plénière (2–3 min/personne).","Synthèse des thèmes transversaux."], av:"Crée une profondeur relationnelle rare. Développe la posture réflexive.", lim:"Requiert du temps. Émotions fortes possibles.", ex:"Module réflexivité clinique : plusieurs cadres infirmiers révèlent des erreurs médicales comme tournants professionnels." },
  { id:"A8", cat:"brise-glace", nom:"Speed Networking Pédagogique", duree:"25–40 min", participants:"12–40", obj:"Permettre de rencontrer rapidement le maximum de collègues ; identifier des complémentarités.", dom:"Savoir-agir — communication", bloom:"Niveau 3", style:"Participatif", mat:"Deux rangées face à face, chronomètre, fiche guidée.", der:["Organisation de l'espace.","Explication des règles (3–4 min/rencontre).","Phase de speed networking (15–20 min).","Notation des contacts.","Mise en commun express."], av:"Maximum de rencontres en minimum de temps. Énergie collective immédiate.", lim:"Anxiogène pour introvertis. Espace adapté nécessaire.", ex:"Journée interprofessionnelle (médecins, sage-femmes, infirmières) : chacun identifie en 30 min ses interlocuteurs naturels." },
  { id:"A9", cat:"brise-glace", nom:"La Carte Postale de Soi", duree:"25–40 min", participants:"6–25", obj:"Permettre une présentation créative et non conventionnelle de soi ; stimuler l'expression métaphorique.", dom:"Savoir-agir — créativité", bloom:"Niveaux 2–6", style:"Permissif et participatif", mat:"Cartes vierges A6/A5, marqueurs, magazines, colle, pastels.", der:["Présentation de la consigne.","Création individuelle (10–15 min).","Circuit de partage silencieux.","Présentation orale.","Exposition murale."], av:"Stimule la créativité. Révèle des dimensions rares de la personnalité.", lim:"Résistance possible chez participants très rationnels.", ex:"Une carte représente une sage-femme tenant un fil reliant naissance et pédagogie — métaphore qui nourrit la réflexion sur les postures." },
  { id:"A10", cat:"brise-glace", nom:"Le Défi des Points Communs", duree:"15–25 min", participants:"8–40", obj:"Créer un sentiment d'appartenance commune malgré les différences ; développer la cohésion.", dom:"Savoir-agir — cohésion", bloom:"Niveau 2", style:"Participatif", mat:"Fiche de défi, chronomètre.", der:["Constitution des groupes (3–5 personnes).","Explication du défi (8 min).","Phase de découverte (8–10 min).","Présentation des découvertes.","Mise en commun et lien pédagogique."], av:"Sentiment immédiat de communauté. Moments de surprise et de rire.", lim:"Peut rester superficiel. Compétition potentiellement stressante.", ex:"Formation interprofessionnelle : le défi révèle une même anxiété face aux erreurs médicales, fondant le contrat collectif." },

  // CO-CONSTRUCTION (15)
  { id:"B1", cat:"co-construction", nom:"Brainstorming", duree:"25–40 min", participants:"8–30", obj:"Activer les représentations initiales ; faire émerger un maximum d'idées ; diagnostiquer les connaissances préalables.", dom:"Savoir — créativité", bloom:"Niveaux 2 et 6", style:"Participatif", mat:"Tableau blanc, marqueurs, post-its, chronomètre.", der:["Mise en contexte — question ouverte.","Production libre (10–15 min) — 4 règles d'Osborn.","Tri et catégorisation.","Synthèse du formateur."], av:"Activation des représentations antérieures. Valorise toutes les contributions.", lim:"Risque de conformité sociale. Blocage en groupes inhibés.", ex:"Module douleur obstétricale : 'Quels mots quand vous pensez à la gestion de la douleur en salle de naissance ?'" },
  { id:"B2", cat:"co-construction", nom:"Travail en Groupe (Apprentissage Coopératif)", duree:"50–90 min", participants:"12–35", obj:"Développer simultanément des compétences disciplinaires et transversales (équipe, leadership, communication).", dom:"Savoir / Savoir-faire / Savoir-agir", bloom:"Niveaux 4–6", style:"Participatif", mat:"Paperboard par groupe, fiche de rôles (4 rôles).", der:["Constitution des groupes hétérogènes.","Briefing de la tâche.","Travail en sous-groupe (25–40 min).","Restitution en plénière.","Synthèse coopérative."], av:"Compétences transférables en équipe. Apprentissage par les pairs (Topping).", lim:"Free rider effect. Conflits relationnels si groupe non outillé.", ex:"4 groupes reçoivent chacun un scénario d'urgence néonatale — synthèse transversale." },
  { id:"B3", cat:"co-construction", nom:"Jeu de Rôle", duree:"45–90 min", participants:"6–20", obj:"Développer des compétences communicationnelles et éthiques en situation simulée.", dom:"Savoir-faire / Savoir-agir", bloom:"Niveau 3 puis 4–5", style:"Participatif", mat:"Fiches de rôles détaillées, grille d'observation.", der:["Distribution et lecture des rôles.","Briefing individuel.","Simulation (15–20 min).","Sortie du rôle — décompression.","Débriefing (20–30 min).","Synthèse théorique."], av:"Compétences non enseignables autrement. Forte mémoire émotionnelle.", lim:"Anxiété possible. Requiert un formateur expérimenté au débriefing.", ex:"Module annonce de mauvaises nouvelles : annonce d'une mort fœtale in utero selon protocole SPIKES." },
  { id:"B4", cat:"co-construction", nom:"Débat Structuré", duree:"50–80 min", participants:"10–30", obj:"Développer la pensée critique et l'argumentation scientifique ; la tolérance à la pluralité des points de vue.", dom:"Savoir / Savoir-agir", bloom:"Niveaux 4–5", style:"Participatif", mat:"Documents de référence par équipe, chronomètre.", der:["Préparation (15–20 min) — attribution des positions.","Arguments d'ouverture (5 min/équipe).","Phase contradictoire (15–20 min).","Questions des observateurs.","Synthèse conclusive nuancée."], av:"Pensée critique et tolérance à l'ambiguïté. Prépare aux concertations pluridisciplinaires.", lim:"Peu adapté aux contenus prescriptifs. Nécessite une modération experte.", ex:"'L'IA peut-elle remplacer le jugement clinique de la sage-femme ?' — analyse des enjeux éthiques, techniques et humains." },
  { id:"B5", cat:"co-construction", nom:"Étude de Cas Clinique", duree:"60–90 min", participants:"12–30", obj:"Développer le raisonnement clinique, l'intégration des savoirs, la décision en contexte d'incertitude.", dom:"Savoir / Savoir-faire / Savoir-agir", bloom:"Niveaux 4–6", style:"Participatif", mat:"Dossier clinique complet, grilles d'analyse.", der:["Présentation du cas.","Analyse individuelle.","Travail en sous-groupe.","Restitution en plénière.","Débriefing et synthèse."], av:"Ancrage situationnel puissant (cognition située). Raisonnement hypothético-déductif.", lim:"Qualité dépendante du cas. Temps de préparation important.", ex:"Primipare 38 SA+3, céphalées, TA 160/105, protéinurie 3+ : diagnostic de pré-éclampsie sévère et CAT." },
  { id:"B6", cat:"co-construction", nom:"Méthode 1-2-4-Tous", duree:"30–50 min", participants:"8–64", obj:"Structurer une progression de la réflexion individuelle vers le collectif ; garantir que chaque voix soit entendue.", dom:"Savoir / Savoir-agir", bloom:"Niveaux 3–5", style:"Participatif", mat:"Post-its, tableau blanc, chronomètre.", der:["Réflexion individuelle (3–5 min).","Échange en binôme (5–7 min).","Partage en quatuor (8–10 min).","Mise en commun (10–15 min).","Synthèse finale."], av:"Participation garantie. Évite les effets de conformité.", lim:"Nombres adaptés (multiples de 4). Chronomètre exigeant.", ex:"Étudiants sage-femmes : 'Que faire face à une parturiente qui refuse la péridurale ?'" },
  { id:"B7", cat:"co-construction", nom:"World Café", duree:"60–120 min", participants:"12–60", obj:"Explorer collectivement plusieurs dimensions d'une problématique complexe ; croiser les perspectives.", dom:"Savoir / Savoir-agir", bloom:"Niveaux 4–6", style:"Participatif et permissif", mat:"Tables façon café, 1 question par table, 1 hôte, paperboards.", der:["Mise en place (5 min).","Premier tour (15–20 min).","Rotations (2–3 × 15 min).","Retour à la table d'origine.","Synthèse en plénière."], av:"Intelligence collective riche. Ambiance informelle libératrice.", lim:"Espace aménageable nécessaire. Qualité dépendante des questions.", ex:"5 tables dans un service de maternité : communication, urgences, douleur, post-partum, coordination — plan qualité institutionnel." },
  { id:"B8", cat:"co-construction", nom:"Jigsaw (Classe Puzzle)", duree:"60–90 min", participants:"12–30", obj:"Rendre chaque apprenant expert d'une partie ; développer interdépendance positive et responsabilisation.", dom:"Savoir / Savoir-faire / Savoir-agir", bloom:"Niveaux 3–6", style:"Participatif", mat:"Documents différenciés par sous-thème.", der:["Groupes experts (5 min).","Phase d'expertise (20–25 min).","Reconfiguration en groupes mixtes.","Enseignement croisé (20–25 min).","Évaluation de l'ensemble."], av:"Responsabilise chaque apprenant. Enseigner = maîtriser.", lim:"Qualité dépendante de chaque expert. Découpe soigneuse exigée.", ex:"Infections néonatales : 5 groupes experts (SB, CMV, toxoplasmose, listériose, virales)." },
  { id:"B9", cat:"co-construction", nom:"Phillips 6-6", duree:"25–40 min", participants:"18–60", obj:"Recueillir rapidement les avis de l'ensemble d'un grand groupe ; participation équitable.", dom:"Savoir / Savoir-agir", bloom:"Niveaux 2–4", style:"Participatif", mat:"Chronomètre, tableau blanc.", der:["Groupes de 6 (2 min).","Discussion de 6 minutes exactes.","Désignation d'un rapporteur.","Tour de parole (1–2 min/groupe).","Synthèse collective."], av:"Très rapide. Participation garantie de tous les groupes.", lim:"6 minutes parfois insuffisantes. Restitution répétitive possible.", ex:"30 sage-femmes : 'Obstacles à l'application des recommandations HAS sur la prévention de la prématurité ?'" },
  { id:"B10", cat:"co-construction", nom:"Aquarium de Poissons (Fish Bowl)", duree:"40–60 min", participants:"12–40", obj:"Permettre à un petit groupe de discuter en profondeur pendant que le reste observe ; analyse des dynamiques.", dom:"Savoir-faire / Savoir-agir", bloom:"Niveaux 4–5", style:"Participatif", mat:"Deux cercles concentriques, grille d'observation.", der:["Organisation en 2 cercles.","Briefing.","Discussion du cercle intérieur (15–20 min).","Chaise vide optionnelle.","Débriefing des observateurs.","Synthèse intégrée."], av:"Développe l'observation analytique. Distance réflexive utile.", lim:"Sentiment d'exposition possible. Cercle extérieur silencieux exigeant.", ex:"Module communication : cercle intérieur (médecin, sage-femme, IDE, AS) gère un briefing d'urgence ; cercle extérieur observe leadership et communication." },
  { id:"B11", cat:"co-construction", nom:"Stations Tournantes", duree:"60–120 min", participants:"12–40", obj:"Explorer activement plusieurs sous-thèmes en rotation ; varier les modalités.", dom:"Savoir / Savoir-faire / Savoir-agir", bloom:"Niveaux 2–5", style:"Participatif", mat:"Espaces distincts, consignes et matériaux par station.", der:["Préparation des N stations.","Présentation globale.","Rotations (N × 15–20 min).","Mise en commun.","Synthèse intégrée."], av:"Variété des modalités. Autonomie des groupes.", lim:"Préparation logistique importante. Auto-discipline exigée.", ex:"Soins du nouveau-né : Station 1 (examen mannequin), 2 (partogramme), 3 (quiz pharmacologie), 4 (vidéo réanimation), 5 (allaitement)." },
  { id:"B12", cat:"co-construction", nom:"Think-Pair-Share", duree:"15–30 min", participants:"8–60", obj:"Structurer la pensée individuelle avant l'échange collectif ; participation de tous ; qualité des contributions.", dom:"Savoir / Savoir-agir", bloom:"Niveaux 2–4", style:"Participatif", mat:"Feuille de travail individuelle ou cahier.", der:["THINK (3–5 min) — silence individuel.","PAIR (5–7 min) — binôme.","SHARE (5–10 min) — plénière.","Synthèse et apports théoriques."], av:"Réflexion avant parole. Rapide à mettre en place.", lim:"Peut paraître simple. Phase individuelle à préserver.", ex:"Raisonnement clinique : 'Face à une parturiente en travail précipité, quelles sont vos trois premières actions ?'" },
  { id:"B13", cat:"co-construction", nom:"Forum Ouvert (Open Space)", duree:"3–8 h", participants:"20–100", obj:"Permettre à un grand groupe de s'auto-organiser autour des thèmes qui lui tiennent à cœur ; intelligence collective sans agenda préconçu.", dom:"Savoir-agir", bloom:"Niveaux 5–6", style:"Permissif", mat:"Grand espace ouvert, mur du marché, tables mobiles.", der:["Ouverture (15–20 min) — 4 principes + loi des deux pieds.","Constitution du marché des sujets (20 min).","Sessions simultanées.","Documentation continue.","Clôture (30 min)."], av:"Intelligence collective sans agenda. Engageant pour professionnels expérimentés.", lim:"Inapproprié si programme précis à couvrir. Espace très grand nécessaire.", ex:"Journée dans un service de maternité : 'Comment améliorer notre prise en charge en sécurité et bienveillance ?' — plan qualité institutionnel." },
  { id:"B14", cat:"co-construction", nom:"Carte Conceptuelle Collective", duree:"40–70 min", participants:"6–30", obj:"Cartographier collectivement les relations entre concepts ; développer la pensée systémique.", dom:"Savoir — structuration", bloom:"Niveaux 4–5", style:"Participatif", mat:"Grandes feuilles A1/A0, post-its de couleurs, marqueurs.", der:["Concept central (5 min).","Production individuelle (5 min).","Affichage et organisation (15–20 min).","Discussion et enrichissement (10–15 min).","Présentation et comparaison."], av:"Rend visible la structure du savoir. Révèle les représentations mentales.", lim:"Chaotique si trop grand ou concept trop large. Pensée visuelle non intuitive pour tous.", ex:"'Grossesse normale' : adaptations cardiovasculaires, modifications hormonales, développement fœtal, nutrition, surveillance, complications — complexité systémique visualisée." },
  { id:"B15", cat:"co-construction", nom:"Simulation Clinique en Équipe", duree:"60–120 min", participants:"6–15", obj:"Entraîner les compétences de travail en équipe pluridisciplinaire dans des situations critiques ; intégrer compétences techniques et non techniques.", dom:"Savoir-faire / Savoir-agir", bloom:"Niveaux 3–5", style:"Participatif", mat:"Mannequin de simulation, matériel clinique complet, grilles TEAM/TeamSTEPPS.", der:["Briefing pré-simulation (15 min).","Scénario (20–30 min).","Pause pédagogique.","Débriefing structuré (30–45 min) — PEARLS ou Advocacy-Inquiry.","Synthèse et transfert."], av:"Compétences techniques ET non techniques. Entraînement sans risque patient (HAS, 2012).", lim:"Coût haute-fidélité. Formateurs spécifiquement formés exigés.", ex:"Scénario HPP avec atonie utérine : équipe pluridisciplinaire applique le protocole. Débriefing sur communication, rôles, gestion du stress." },

  // ÉVALUATION (10)
  { id:"C1", cat:"evaluation", nom:"Quiz Interactif (Kahoot / Wooclap)", duree:"15–30 min", participants:"8–200", obj:"Évaluer de manière formative et ludique les connaissances ; identifier les lacunes en temps réel ; maintenir l'engagement.", dom:"Savoir", bloom:"Niveaux 1–3", style:"Participatif", mat:"Ordinateur, vidéoprojecteur, smartphones, compte Kahoot/Wooclap.", der:["Préparation du quiz (10–20 questions).","Connexion des participants.","Déroulement du quiz (10–20 min).","Correction immédiate et explication.","Synthèse et classement."], av:"Rétroaction immédiate. Engagement maintenu. Grand groupe possible.", lim:"Connexion internet et appareils requis. Questions binaires limitent Bloom supérieur.", ex:"Fin de module pharmacologie obstétricale : Kahoot 15 questions sur dosages et contre-indications des utérotoniques." },
  { id:"C2", cat:"evaluation", nom:"Ticket de Sortie (Exit Ticket)", duree:"5–10 min", participants:"8–200", obj:"Recueillir une rétroaction rapide sur les apprentissages ; identifier les points de confusion ; réguler l'enseignement.", dom:"Savoir — métacognition", bloom:"Niveaux 1–3", style:"Participatif", mat:"Petites fiches papier ou formulaire numérique.", der:["Annonce en fin de séance.","Réponse individuelle écrite (3–5 min).","Collecte anonyme.","Analyse entre séances.","Rétroaction au groupe suivant."], av:"Très rapide et peu intrusif. Information précieuse. Régulation entre séances.", lim:"Réponses superficielles possibles. Anonymat à préserver.", ex:"Fin de séance partogramme : '1 info retenue / 1 point pas clair / 1 situation où appliquer'." },
  { id:"C3", cat:"evaluation", nom:"OSCE (Examen Clinique Objectif Structuré)", duree:"5–15 min/station", participants:"1/station", obj:"Évaluer objectivement et de manière standardisée les compétences cliniques pratiques ; certifier la maîtrise des gestes.", dom:"Savoir-faire / Savoir-agir", bloom:"Niveaux 3–5", style:"Directif", mat:"Stations équipées, grilles OSCE standardisées, patients simulés.", der:["Préparation et standardisation.","Briefing général.","Rotation dans les stations.","Évaluation en temps réel.","Feedback individuel."], av:"Évaluation objective. Couvre technique et communicationnel. Gold standard international.", lim:"Organisation logistique complexe et coûteuse. Évalue des compétences isolées.", ex:"OSCE sage-femme : 5 stations — TV + interprétation, annonce résultat, lecture CTG, dose oxytocine, examen nouveau-né." },
  { id:"C4", cat:"evaluation", nom:"Test de Concordance de Script (TCS)", duree:"30–60 min", participants:"6–200", obj:"Évaluer le raisonnement clinique en situation d'incertitude ; mesurer la progression vers l'expertise.", dom:"Savoir-agir", bloom:"Niveaux 4–5", style:"Directif puis participatif", mat:"Cahier de test TCS, échelle de Likert, clé panel d'experts.", der:["Conception validée par panel d'experts.","Présentation du format.","Passation individuelle (30–45 min).","Notation automatisée.","Débriefing collectif (30 min)."], av:"Mesure le raisonnement réel en incertitude. Sensible à la progression débutant-expert (Charlin et al., 2000).", lim:"Conception complexe. Format peu familier sans formation préalable.", ex:"Vignette TCS : primipare, stagnation dilatation à 7 cm, poche intacte → hypothèse de dystocie dynamique devient… (échelle Likert)." },
  { id:"C5", cat:"evaluation", nom:"Portfolio Réflexif", duree:"Continu", participants:"Individuel", obj:"Favoriser la posture réflexive du praticien ; documenter la progression ; intégrer théorie et pratique.", dom:"Savoir-agir — réflexivité", bloom:"Niveaux 4–6", style:"Permissif et participatif", mat:"Classeur ou e-portfolio, guide de réflexion, grille d'évaluation.", der:["Présentation du portfolio.","Construction progressive continue.","Séances de supervision régulières.","Évaluation sommative finale.","Soutenance optionnelle."], av:"Développe la posture réflexive (Schön, 1983). Progression longitudinale visible.", lim:"Investissement temporel important. Évaluation subjective.", ex:"Master PSTS : portfolio d'expériences d'enseignement, analyses de séances et lectures critiques — soutenance finale = 50% de l'évaluation." },
