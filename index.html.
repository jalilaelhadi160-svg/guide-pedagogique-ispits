<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Guide pédagogique — Master PSTS · ISPITS. Styles d'animation, méthodes pédagogiques, supports et 35 techniques pour les formateurs en sciences de la santé.">
<title>Guide Pédagogique · Master PSTS — ISPITS</title>

<!-- Typography: Fraunces (distinctive variable serif) + Instrument Sans (clean body) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
/* =============================================================
   DESIGN TOKENS — editorial academic palette
   ============================================================= */
:root {
  /* Colours — warm, editorial, academic (NOT tech-blue/purple) */
  --ink:          #14213D;     /* deep ink — primary text */
  --ink-soft:     #4A5568;     /* secondary text */
  --ink-muted:    #8B8683;     /* tertiary / captions */
  --paper:        #F7F2E8;     /* warm cream — base background */
  --paper-deep:   #EEE6D3;     /* slightly deeper cream for sections */
  --paper-dark:   #E5DCC3;     /* darkest cream variant */
  --line:         #C9BFA8;     /* rule lines */

  /* Accents */
  --terracotta:   #C8553A;     /* primary accent — hot */
  --terracotta-d: #A63F28;     /* terracotta deeper */
  --navy:         #1B3A6B;     /* academic navy — co-construction */
  --forest:       #1A6B3C;     /* academic green — brise-glace */
  --bordeaux:     #7B241C;     /* academic bordeaux — évaluation */
  --gold:         #B08B2E;     /* gold — highlights */

  /* Type scale (fluid) */
  --step-6: clamp(3rem, 2rem + 5vw, 6.5rem);
  --step-5: clamp(2.25rem, 1.6rem + 3vw, 4.5rem);
  --step-4: clamp(1.75rem, 1.3rem + 2vw, 3rem);
  --step-3: clamp(1.375rem, 1.15rem + 1.1vw, 2rem);
  --step-2: clamp(1.125rem, 1rem + 0.4vw, 1.375rem);
  --step-1: 1rem;
  --step-0: 0.9375rem;
  --step-s: 0.8125rem;
  --step-xs: 0.6875rem;

  /* Rhythm */
  --unit: 0.25rem;
  --gutter: clamp(1.25rem, 2.5vw, 2.25rem);
  --section-y: clamp(4rem, 8vw, 8rem);

  /* Fonts */
  --f-display: "Fraunces", "Apple Garamond", Georgia, serif;
  --f-body:    "Instrument Sans", -apple-system, system-ui, sans-serif;
  --f-mono:    "JetBrains Mono", "Menlo", monospace;

  /* Easings */
  --ease: cubic-bezier(0.22, 0.61, 0.36, 1);
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
}

/* =============================================================
   RESET & BASE
   ============================================================= */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; scroll-padding-top: 5rem; }
body {
  background: var(--paper);
  color: var(--ink);
  font-family: var(--f-body);
  font-size: var(--step-1);
  line-height: 1.65;
  font-weight: 400;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  overflow-x: hidden;
  font-feature-settings: "ss01", "cv01";
}

/* Subtle paper grain — gives the page warmth without being loud */
body::before {
  content: "";
  position: fixed; inset: 0;
  pointer-events: none;
  opacity: 0.35;
  z-index: 1;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.45'/%3E%3C/svg%3E");
  mix-blend-mode: multiply;
}

img { max-width: 100%; display: block; }
button { font: inherit; cursor: pointer; border: 0; background: none; color: inherit; }
a { color: inherit; text-decoration: none; }

/* Typography */
h1, h2, h3, h4 {
  font-family: var(--f-display);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--ink);
  font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 0;
}
h1 { font-size: var(--step-6); }
h2 { font-size: var(--step-5); }
h3 { font-size: var(--step-3); }
h4 { font-size: var(--step-2); font-weight: 500; letter-spacing: -0.01em; line-height: 1.2; }

p { max-width: 65ch; }
em, .italic { font-family: var(--f-display); font-style: italic; font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1; }

/* Selection */
::selection { background: var(--terracotta); color: var(--paper); }

/* Eyebrow / kicker labels */
.kicker {
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-weight: 500;
  color: var(--terracotta);
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
}
.kicker::before {
  content: "";
  width: 2rem; height: 1px;
  background: var(--terracotta);
}

/* Section number (editorial) */
.numero {
  font-family: var(--f-display);
  font-weight: 300;
  font-style: italic;
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  color: var(--terracotta);
  font-size: clamp(4rem, 8vw, 7rem);
  line-height: 1;
}

/* =============================================================
   LAYOUT UTILITIES
   ============================================================= */
.wrap { max-width: 84rem; margin: 0 auto; padding: 0 var(--gutter); position: relative; z-index: 2; }
.wrap-narrow { max-width: 58rem; margin: 0 auto; padding: 0 var(--gutter); position: relative; z-index: 2; }
.section { padding: var(--section-y) 0; position: relative; z-index: 2; }

/* Editorial rule */
.rule { height: 1px; background: var(--line); margin: 0; border: 0; }

/* =============================================================
   NAV
   ============================================================= */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  padding: 1rem var(--gutter);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.4s var(--ease);
  background: transparent;
}
.nav.scrolled {
  background: rgba(247, 242, 232, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--line);
}
.nav__brand {
  font-family: var(--f-display);
  font-weight: 500;
  font-size: 1.1rem;
  letter-spacing: -0.01em;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.nav__brand-mark {
  width: 2rem; height: 2rem;
  border-radius: 50%;
  background: var(--ink);
  color: var(--paper);
  display: grid; place-items: center;
  font-family: var(--f-display);
  font-style: italic;
  font-size: 0.95rem;
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
}
.nav__menu {
  display: flex;
  gap: 0.4rem;
  align-items: center;
  list-style: none;
}
.nav__link {
  font-size: var(--step-s);
  padding: 0.55rem 0.95rem;
  border-radius: 999px;
  color: var(--ink-soft);
  font-weight: 500;
  letter-spacing: 0.01em;
  transition: all 0.25s var(--ease);
}
.nav__link:hover { color: var(--ink); background: var(--paper-deep); }
.nav__link.active { color: var(--paper); background: var(--ink); }
.nav__cta {
  padding: 0.55rem 1.1rem;
  background: var(--terracotta);
  color: var(--paper);
  border-radius: 999px;
  font-size: var(--step-s);
  font-weight: 500;
  margin-left: 0.5rem;
  transition: all 0.25s var(--ease);
}
.nav__cta:hover { background: var(--terracotta-d); transform: translateY(-1px); }
.nav__burger { display: none; }
@media (max-width: 900px) {
  .nav__menu { display: none; }
  .nav__menu.open {
    display: flex;
    position: absolute;
    flex-direction: column;
    top: 100%; right: var(--gutter);
    background: var(--paper);
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    min-width: 14rem;
    gap: 0.2rem;
    box-shadow: 0 20px 40px -10px rgba(20, 33, 61, 0.15);
  }
  .nav__menu.open .nav__link { display: block; }
  .nav__burger {
    display: flex; flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    border-radius: 8px;
  }
  .nav__burger span {
    width: 22px; height: 2px; background: var(--ink);
    transition: transform 0.3s var(--ease);
  }
}

/* =============================================================
   HERO
   ============================================================= */
.hero {
  min-height: 100vh;
  padding: 8rem 0 var(--section-y);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* Decorative big-mark in background */
.hero__decor {
  position: absolute;
  top: 10%; right: -5%;
  font-family: var(--f-display);
  font-style: italic;
  font-size: clamp(20rem, 40vw, 42rem);
  color: var(--paper-deep);
  line-height: 1;
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  z-index: 1;
  user-select: none;
  pointer-events: none;
  font-weight: 300;
}

.hero__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: end;
  position: relative;
  z-index: 2;
}
@media (min-width: 960px) {
  .hero__grid { grid-template-columns: 1.3fr 1fr; }
}

.hero__meta {
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.22em;
  color: var(--ink-soft);
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.hero__meta span + span { position: relative; padding-left: 2rem; }
.hero__meta span + span::before {
  content: ""; position: absolute; left: 0; top: 50%;
  width: 1rem; height: 1px; background: var(--line);
}

.hero__title {
  font-size: clamp(2.75rem, 7vw, 6rem);
  line-height: 0.98;
  letter-spacing: -0.035em;
  margin-bottom: 1.5rem;
  font-weight: 300;
}
.hero__title em {
  color: var(--terracotta);
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  font-weight: 400;
}

.hero__lede {
  font-size: var(--step-2);
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 38ch;
  margin-bottom: 2.5rem;
}

.hero__ctas {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  align-items: center;
}

/* Button system */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.95rem 1.5rem;
  border-radius: 999px;
  font-weight: 500;
  font-size: var(--step-0);
  transition: all 0.3s var(--ease);
  letter-spacing: -0.005em;
}
.btn-primary {
  background: var(--ink);
  color: var(--paper);
}
.btn-primary:hover {
  background: var(--terracotta);
  transform: translateY(-2px);
  box-shadow: 0 10px 25px -10px rgba(200, 85, 58, 0.5);
}
.btn-ghost {
  border: 1px solid var(--ink);
  color: var(--ink);
}
.btn-ghost:hover { background: var(--ink); color: var(--paper); }
.btn__arrow {
  transition: transform 0.3s var(--ease);
  display: inline-block;
}
.btn:hover .btn__arrow { transform: translateX(4px); }

/* Hero stats column */
.hero__stats {
  display: grid;
  gap: 1.5rem;
  border-top: 1px solid var(--line);
  padding-top: 2rem;
}
.stat {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1.5rem;
  align-items: baseline;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--line);
}
.stat:last-child { border-bottom: 0; }
.stat__num {
  font-family: var(--f-display);
  font-size: clamp(2.5rem, 5vw, 3.75rem);
  font-weight: 300;
  font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
  line-height: 1;
  color: var(--ink);
}
.stat__label {
  font-size: var(--step-s);
  line-height: 1.35;
  color: var(--ink-soft);
  max-width: 20ch;
}

/* =============================================================
   INTRO / EPIGRAPH
   ============================================================= */
.intro {
  background: var(--paper-deep);
  padding: var(--section-y) 0;
  position: relative;
}
.intro__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: start;
}
@media (min-width: 900px) {
  .intro__grid { grid-template-columns: 1fr 2fr; }
}
.intro__label {
  position: sticky;
  top: 6rem;
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.22em;
  color: var(--ink-soft);
}
.intro__label strong {
  display: block;
  font-family: var(--f-display);
  font-size: var(--step-2);
  font-style: italic;
  font-weight: 400;
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  letter-spacing: -0.01em;
  color: var(--ink);
  margin-top: 0.5rem;
  text-transform: none;
}
.intro__text p {
  font-size: var(--step-2);
  line-height: 1.55;
  color: var(--ink);
  margin-bottom: 1.5rem;
  max-width: 62ch;
}
.intro__text p:first-of-type::first-letter {
  font-family: var(--f-display);
  font-size: 4.5em;
  float: left;
  line-height: 0.85;
  margin: 0.05em 0.08em 0 0;
  color: var(--terracotta);
  font-weight: 400;
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
}

/* =============================================================
   SECTION HEADER (shared)
   ============================================================= */
.sec-head {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  align-items: end;
  margin-bottom: 4rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--line);
}
@media (min-width: 900px) {
  .sec-head { grid-template-columns: auto 1fr auto; gap: 3rem; }
}
.sec-head__numero { grid-row: 1; }
.sec-head__title h2 {
  font-weight: 300;
  line-height: 1;
}
.sec-head__title em {
  color: var(--terracotta);
}
.sec-head__meta {
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--ink-muted);
  text-align: right;
}

/* =============================================================
   SECTION 1 — STYLES D'ANIMATION
   ============================================================= */
.styles-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-top: 2rem;
}
@media (min-width: 700px) {
  .styles-grid { grid-template-columns: repeat(3, 1fr); }
}

.style-card {
  padding: 2.5rem 2rem;
  background: var(--paper-deep);
  border: 1px solid var(--line);
  border-radius: 4px;
  position: relative;
  transition: all 0.4s var(--ease);
  overflow: hidden;
  cursor: pointer;
}
.style-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px -20px rgba(20, 33, 61, 0.2);
}
.style-card__tag {
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--ink-muted);
  margin-bottom: 1rem;
}
.style-card__name {
  font-family: var(--f-display);
  font-size: clamp(1.75rem, 3vw, 2.25rem);
  line-height: 1;
  margin-bottom: 1.25rem;
  font-weight: 400;
  font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
}
.style-card__desc {
  font-size: var(--step-0);
  color: var(--ink-soft);
  line-height: 1.55;
  margin-bottom: 1.5rem;
}
.style-card__props {
  list-style: none;
  font-size: var(--step-s);
  display: grid;
  gap: 0.4rem;
  border-top: 1px solid var(--line);
  padding-top: 1rem;
}
.style-card__props li {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
  line-height: 1.4;
}
.style-card__props li span:first-child {
  color: var(--ink-muted);
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.style-card--directif {
  border-top: 3px solid var(--bordeaux);
}
.style-card--directif .style-card__name { color: var(--bordeaux); }
.style-card--permissif {
  border-top: 3px solid var(--forest);
}
.style-card--permissif .style-card__name { color: var(--forest); }
.style-card--participatif {
  border-top: 3px solid var(--navy);
  background: var(--paper-dark);
}
.style-card--participatif .style-card__name { color: var(--navy); }

.style-card__recommended {
  position: absolute;
  top: 1.25rem; right: 1.25rem;
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  letter-spacing: 0.15em;
  background: var(--navy);
  color: var(--paper);
  padding: 0.25rem 0.6rem;
  border-radius: 4px;
  text-transform: uppercase;
}

/* =============================================================
   SECTION 2 — MÉTHODES
   ============================================================= */
.methodes-intro {
  max-width: 62ch;
  font-size: var(--step-2);
  line-height: 1.55;
  color: var(--ink-soft);
  margin-bottom: 3.5rem;
}

.methodes-tabs {
  display: flex;
  gap: 0.5rem;
  border-bottom: 1px solid var(--line);
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}
.methodes-tab {
  padding: 1rem 1.5rem;
  font-family: var(--f-display);
  font-size: var(--step-3);
  font-weight: 400;
  font-style: italic;
  font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  color: var(--ink-muted);
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 0.3s var(--ease);
}
.methodes-tab:hover { color: var(--ink); }
.methodes-tab.active {
  color: var(--terracotta);
  border-bottom-color: var(--terracotta);
}

.methodes-panel { display: none; }
.methodes-panel.active { display: block; animation: fadeUp 0.5s var(--ease-out); }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.methodes-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  list-style: none;
}
.methode {
  padding: 2rem 0;
  border-top: 1px solid var(--line);
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  transition: padding 0.3s var(--ease);
}
.methode:hover { padding-left: 0.5rem; }
@media (min-width: 800px) {
  .methode {
    grid-template-columns: 12rem 1fr auto;
    gap: 3rem;
    align-items: start;
  }
}
.methode__name {
  font-family: var(--f-display);
  font-size: var(--step-3);
  line-height: 1;
  font-weight: 400;
  color: var(--ink);
}
.methode__desc {
  font-size: var(--step-0);
  color: var(--ink-soft);
  max-width: 55ch;
  line-height: 1.55;
}
.methode__bloom {
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--terracotta);
  padding: 0.35rem 0.75rem;
  border: 1px solid var(--terracotta);
  border-radius: 999px;
  white-space: nowrap;
  align-self: start;
  justify-self: start;
}
@media (min-width: 800px) {
  .methode__bloom { justify-self: end; }
}

/* =============================================================
   SECTION 3 — SUPPORTS
   ============================================================= */
.supports-intro {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  margin-bottom: 4rem;
}
@media (min-width: 900px) {
  .supports-intro { grid-template-columns: 1fr 1fr; }
}
.supports-intro__text { font-size: var(--step-2); line-height: 1.55; color: var(--ink-soft); }
.supports-intro__text p + p { margin-top: 1rem; }

.critere-accordion {
  border-top: 1px solid var(--ink);
}
.critere {
  border-bottom: 1px solid var(--line);
}
.critere__head {
  width: 100%;
  text-align: left;
  padding: 1.5rem 0;
  display: flex;
  align-items: center;
  gap: 1rem;
  justify-content: space-between;
  transition: color 0.3s var(--ease);
}
.critere__head:hover { color: var(--terracotta); }
.critere__num {
  font-family: var(--f-mono);
  font-size: var(--step-xs);
  color: var(--ink-muted);
  letter-spacing: 0.1em;
  min-width: 2rem;
}
.critere__label {
  font-family: var(--f-display);
  font-size: var(--step-3);
  font-weight: 400;
  flex: 1;
  text-align: left;
  line-height: 1.15;
}
.critere__icon {
  font-family: var(--f-display);
  font-size: 1.5rem;
  font-weight: 300;
